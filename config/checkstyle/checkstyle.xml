<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  OMS Checkstyle 규칙
  목적: AI 에이전트가 생성한 코드의 스타일 일관성을 기계적으로 강제한다.
  참조: docs/guardrails/code-style.md
  위반 시: ./gradlew checkstyleMain 빌드 실패
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>

    <!-- 파일 레벨 규칙 -->
    <module name="FileTabCharacter">
        <!-- 탭 문자 금지 — 스페이스만 허용 -->
        <property name="eachLine" value="true"/>
    </module>

    <module name="NewlineAtEndOfFile">
        <!-- 파일 마지막에 개행 필수 -->
        <property name="lineSeparator" value="lf, crlf"/>
    </module>

    <module name="TreeWalker">

        <!-- ── 임포트 규칙 ── -->
        <module name="AvoidStarImport">
            <!-- 와일드카드 임포트 금지: import java.util.* -->
        </module>

        <module name="UnusedImports">
            <!-- 사용하지 않는 임포트 금지 -->
        </module>

        <module name="IllegalImport">
            <!-- 금지된 패키지 임포트 -->
            <property name="illegalPkgs" value="sun, com.sun"/>
        </module>

        <!-- ── 명명 규칙 ── -->
        <module name="TypeName">
            <!-- 클래스·인터페이스: PascalCase -->
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <module name="MethodName">
            <!-- 메서드명: camelCase -->
            <property name="format" value="^[a-z][a-zA-Z0-9_]*$"/>
        </module>

        <module name="ConstantName">
            <!-- 상수: UPPER_SNAKE_CASE -->
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>

        <module name="LocalVariableName">
            <!-- 지역 변수: camelCase -->
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <module name="PackageName">
            <!-- 패키지명: 소문자만 -->
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- ── 코드 품질 규칙 ── -->
        <module name="EmptyCatchBlock">
            <!-- 빈 catch 블록 금지 — 예외를 무음으로 삼키지 않는다 -->
            <property name="exceptionVariableName" value="expected|ignore"/>
        </module>

        <module name="EqualsHashCode">
            <!-- equals() 구현 시 hashCode()도 반드시 구현 -->
        </module>

        <module name="SimplifyBooleanExpression">
            <!-- 불필요한 boolean 식 단순화 -->
        </module>

        <module name="StringLiteralEquality">
            <!-- 문자열 비교는 equals() 사용 — == 금지 -->
        </module>

        <module name="MagicNumber">
            <!-- 매직 넘버 금지 — 상수로 추출 -->
            <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
            <property name="ignoreAnnotation" value="true"/>
            <property name="ignoreHashCodeMethod" value="true"/>
        </module>

        <!-- ── 공백·형식 규칙 ── -->
        <module name="WhitespaceAfter">
            <!-- 쉼표·세미콜론 뒤 공백 필수 -->
            <property name="tokens" value="COMMA, SEMI"/>
        </module>

        <module name="NoWhitespaceBefore">
            <!-- 세미콜론 앞 공백 금지 -->
            <property name="tokens" value="SEMI"/>
        </module>

        <module name="OperatorWrap">
            <!-- 연산자는 줄 바꿈 전에 위치 -->
            <property name="option" value="nl"/>
            <property name="tokens" value="BAND, BOR, BSR, BXOR, DIV, LAND, LOR, MINUS, MOD, PLUS, SL, SR, STAR"/>
        </module>

    </module>
</module>